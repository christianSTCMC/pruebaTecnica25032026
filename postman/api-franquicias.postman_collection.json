  "item": [
    {
      "name": "Franquicias",
      "item": [
        {
          "name": "Crear Franquicia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Franquicia Centro\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/franquicias",
            "description": "Crea una franquicia nueva."
          }
        },
        {
          "name": "Listar Franquicias",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/franquicias",
            "description": "Obtiene el listado independiente de franquicias."
          }
        }
      ]
    },
    {
      "name": "Sucursales",
      "item": [
        {
          "name": "Crear Sucursal en Franquicia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Sucursal Norte\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/franquicias/{{franquiciaId}}/sucursales",
            "description": "Crea una sucursal dentro de la franquicia indicada."
          }
        },
        {
          "name": "Listar Sucursales",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/sucursales",
            "description": "Obtiene el listado independiente de sucursales."
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Crear Producto en Sucursal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop Gamer\",\n  \"stock\": 15\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/sucursales/{{sucursalId}}/productos",
            "description": "Crea un producto en la sucursal indicada."
          }
        },
        {
          "name": "Listar Productos",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/productos",
            "description": "Obtiene el listado independiente de productos."
          }
        },
        {
          "name": "Actualizar Stock Producto",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stock\": 30\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/v1/productos/{{productoId}}/stock",
            "description": "Actualiza el stock del producto."
          }
        },
        {
          "name": "Eliminar Producto de Sucursal",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/v1/sucursales/{{sucursalId}}/productos/{{productoId}}",
            "description": "Elimina el producto indicado de la sucursal indicada."
          }
        }
      ]
    },
    {
      "name": "Consultas Especiales",
      "item": [
        {
          "name": "Mayor Stock por Sucursal",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/franquicias/{{franquiciaId}}/productos/mayor-stock-por-sucursal",
            "description": "Obtiene el producto con mayor stock por sucursal para la franquicia indicada."
          }
        }
      ]
    }
  ],
